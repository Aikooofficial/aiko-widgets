{
  "version": 2,
  "public": true,
  "rewrites": [
    { "source": "/", "destination": "/public/index.html" },
    { "source": "/ngn", "destination": "/public/ngn.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "s-maxage=15, stale-while-revalidate=30" }
      ]
    }
  ]
}
